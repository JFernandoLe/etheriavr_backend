# --- CONFIGURACIÓN DE BASE DE DATOS (MYSQL) ---
# Contraseña del usuario root de la base de datos
MYSQL_ROOT_PASSWORD=tu_root_password_aqui
# Nombre de la base de datos para EtheriaVR
MYSQL_DATABASE=etheriavr_db
# Usuario de la aplicación
MYSQL_USER=tu_usuario_aqui
# Contraseña del usuario de la aplicación
MYSQL_PASSWORD=tu_password_aqui

# Conexión local o remota
DB_HOST=localhost
DB_PORT=3306

# --- CONFIGURACIÓN DE LA APP (FASTAPI) ---
APP_HOST=0.0.0.0
APP_PORT=8000
# Cambiar a False en producción para mayor seguridad
DEBUG_MODE=True

# --- SEGURIDAD Y JWT ---
# Generar una clave real con: openssl rand -hex 32
SECRET_KEY=tu_clave_secreta_super_larga_aqui
ALGORITHM=HS256
# Tiempo de vida del token (ej. 43200 = 30 días)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# --- ETHERIA BROADCAST SERVICE (UDP BEACON) ---
# Puerto para el descubrimiento del servidor en la red local
UDP_PORT=8888
# Palabra mágica que espera el visor Meta Quest 3
MAGIC_WORD=ETHERIA_SEARCH
# Identificador de respuesta del servidor
SERVER_IDENTIFIER=ETHERIA_SERVER_HERE
# DNS para validar la IP local (por defecto Google)
DNS_HELPER=8.8.8.8